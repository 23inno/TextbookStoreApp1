<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <variable
            name="bookTitle"
            type="String" />

        <variable
            name="bookAuthor"
            type="String" />

        <variable
            name="bookEdition"
            type="String" />

        <variable
            name="bookPrice"
            type="String" />

        <variable
            name="bookDescription"
            type="String" />

    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imgBook"
                android:layout_width="150dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_background"
                android:contentDescription="Book image" />

            <TextView
                android:id="@+id/tvBookName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{bookTitle}"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='@{"Author: " + bookAuthor}'
                android:textSize="18sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvEdition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='@{"Edition: " + bookEdition}'
                android:textSize="18sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvBookPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='@{"Price: " + bookPrice}'
                android:textSize="18sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{bookDescription}"
                android:textSize="16sp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnContactSeller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contact Seller"
                android:layout_marginTop="20dp" />

        </LinearLayout>

    </ScrollView>

</layout>